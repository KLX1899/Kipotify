PORT=18080
DATABASE_URL=postgres://kipotify:kipotify@localhost:15432/kipotify?sslmode=disable
JWT_SECRET=replace-with-a-long-random-secret
JWT_ISSUER=kipotify
JWT_TTL_HOURS=168
CORS_ORIGINS=*
RUN_MIGRATIONS=true
RUN_SEED=true
ALLOW_DEMO_AUTH=true
MDNS_ENABLED=true
# HTTPS is required for Android LAN discovery in production. The certificate must contain the
# backend's LAN IP address as an IP subject alternative name.
TLS_CERT_FILE=
TLS_KEY_FILE=
MDNS_INSTANCE=Kipotify
MDNS_PRIORITY=0
# Optional exact interface override for unusual virtual or routed LAN setups.
MDNS_INTERFACE=
# Development only. Requires KIPOTIFY_ALLOW_INSECURE_LAN=true in Client/gradle.properties.
MDNS_ADVERTISE_INSECURE=false
